{
  "name": "pwa-generator",
  "version": "1.0.0",
  "description": "PWA Generator with AI",
  "main": "app.py",
  "scripts": {
    "build-css": "tailwindcss -i ./static/src/input.css -o ./static/styles.css",
    "build-css-prod": "NODE_ENV=production tailwindcss -i ./static/src/input.css -o ./static/styles.css",
    "watch-css": "tailwindcss -i ./static/src/input.css -o ./static/styles.css --watch"
  },
  "keywords": [
    "pwa",
    "ai",
    "generator"
  ],
  "author": "PWA Generator",
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
